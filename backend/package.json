{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/database-server.js",
    "start:simple": "node src/simple-server.js",
    "start:original": "node src/server.js",
    "build": "echo 'No build step required'",
    "test": "cd .. && node --experimental-vm-modules node_modules/.bin/jest --runInBand --config backend/jest.config.js",
    "test:watch": "node --experimental-vm-modules $(npx which jest) --watch --runInBand",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "setup": "node src/scripts/setup.js",
    "setup:db": "node src/database/setup-db.js",
    "health": "node src/database/health-check.js",
    "db:reset": "npm run migrate && npm run seed",
    "fix-admin": "node src/scripts/fix-admin.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^6.0.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.9.0",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.4.0",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "nodemon": "^2.0.20",
    "supertest": "^6.3.4"
  }
}
