# Local Environment Overrides
# This file is for local development overrides and should not be committed to git
# Copy this to .env.local and customize for your local setup

# Database Configuration (override for local development)
# DATABASE_URL=postgresql://postgres:your_local_password@localhost:5432/ecommerce_dev

# Session Configuration (override for local development)
# SESSION_SECRET=your-local-session-secret

# Admin Configuration (override for local development)
# ADMIN_EMAIL=your-admin@localhost.com
# ADMIN_PASSWORD=your-local-admin-password

# Logging Configuration (override for local development)
# LOG_LEVEL=debug

# Development Tools
# ENABLE_QUERY_LOGGING=true
# ENABLE_DEBUG_MODE=true